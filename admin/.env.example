# ── CropSetu Admin SPA env ────────────────────────────────────────────────────

# Base URL of the backend admin API. The client calls `${VITE_API_URL}/admin/*`
# and `${VITE_API_URL}/auth/*`. Default '/api/v1' uses the Vite dev proxy (below)
# / same-origin reverse proxy in prod, which keeps cookies first-party and CSRF
# simple. Set to an absolute origin (e.g. https://api.cropsetu.app/api/v1) only if
# the admin app is served from a DIFFERENT origin than the API — then that admin
# origin MUST also be added to the backend's ALLOWED_ORIGINS.
VITE_API_URL=/api/v1

# Dev-only: where `vite dev` proxies /api to (your running backend).
VITE_API_PROXY=http://localhost:3000

# Shown in the top-bar environment badge (e.g. local | staging | production).
VITE_ENV_NAME=local
