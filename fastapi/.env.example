# ═════════════════════════════════════════════════════════════════════════════
# CropSetu FastAPI AI Service — Environment Variables
#
# CropSetu is GEMINI-FIRST. Every LLM feature runs on Google Gemini; Anthropic
# was removed during the production consolidation. Voice STT/TTS is handled by
# Sarvam in the Express backend.
#
# How model selection works
#   Each AI feature has two optional overrides:
#     AI_<FEATURE>_MODEL=<gemini-model-id>   (e.g. gemini-2.5-pro)
#     AI_<FEATURE>_API_KEY=<key>             (defaults to GEMINI_API_KEY)
#   Only 'gemini-*' model ids are accepted; anything else fails fast at config
#   resolution. Leave the per-feature lines unset to use the gemini-2.5-flash
#   defaults.
#
#   The ONE exception is the text-chat fallback: when the Gemini path is fully
#   down, chat falls back to Groq (Llama) so the farmer still gets a reply. It is
#   optional and only fires when GROQ_API_KEY is set (see section 3).
# ═════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# 1. Server
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=8001


# ─────────────────────────────────────────────────────────────────────────────
# 2. Database & cache
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis — idempotency cache (db 0) + Celery broker/results (db 1).
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Rate-limit storage. SlowAPI is per-process by default, so in a multi-instance
# deployment the limit is enforced PER INSTANCE (effectively N× looser). Point it
# at Redis to share the window across the fleet. Defaults to REDIS_URL when set,
# else in-memory. Falls back to in-memory automatically if Redis is unreachable.
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379/2
# REDIS_URL=redis://localhost:6379/0


# ─────────────────────────────────────────────────────────────────────────────
# 3. API KEYS
# ─────────────────────────────────────────────────────────────────────────────
# Google Gemini — sole LLM provider → https://aistudio.google.com/apikey
# REQUIRED. In production the service refuses to start without it.
GEMINI_API_KEY=

# Sarvam (Indic STT/TTS/translate, not an LLM) → https://dashboard.sarvam.ai
SARVAM_API_KEY=

# Groq — OPTIONAL text-chat fallback → https://console.groq.com/keys
# When set, the text-chat features (TEXT_CHAT / CHAT_WRITER / CHAT_ENHANCER) fall
# back to Groq's free Llama tier if the Gemini path (primary + Flash↔Pro capacity
# fallback) is fully down, so chat survives a Gemini-side outage. Leave blank to
# stay Gemini-only (chat then fails hard on a Gemini outage). Text-only — the
# vision/diagnose paths never use Groq. Override the model with
# GROQ_FALLBACK_MODEL (default llama-3.3-70b-versatile) or per-feature with
# AI_<FEATURE>_GROQ_MODEL; disable per-feature with AI_<FEATURE>_GROQ_FALLBACK=false.
GROQ_API_KEY=
# GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# OpenAI — OPTIONAL crop-diagnosis ensemble voter → https://platform.openai.com/api-keys
# When set, GPT-4o joins the crop-disease diagnosis ENSEMBLE as one extra
# cross-vendor vision voter alongside Gemini Pro + Flash; the reconciler fuses
# its opinion on uncertain scans. It participates ONLY when (a) this key is set
# AND (b) the ensemble actually fires — which needs ENABLE_ENSEMBLE=true (see
# section 7) and a low-confidence/ambiguous scan. Leave blank to stay Gemini-only.
# Swap the model with OPENAI_DIAGNOSE_MODEL (default gpt-4o; must be vision-capable).
OPENAI_API_KEY=
# OPENAI_DIAGNOSE_MODEL=gpt-4o


# ─────────────────────────────────────────────────────────────────────────────
# 4. Other data sources (optional)
# ─────────────────────────────────────────────────────────────────────────────
DATA_GOV_API_KEY=
OPENWEATHER_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# 5. Security
# ─────────────────────────────────────────────────────────────────────────────
# HMAC shared with Express. Generate a fresh 32-byte hex per environment.
AI_SHARED_SECRET=
AI_ALLOWED_ORIGINS=http://localhost:3001


# ═════════════════════════════════════════════════════════════════════════════
# 6. ▼ PER-FEATURE MODEL OVERRIDES (all Gemini; optional) ▼
# ═════════════════════════════════════════════════════════════════════════════
# Every feature defaults to gemini-2.5-flash with GEMINI_API_KEY. Override a
# model only to move a feature to gemini-2.5-pro (more accuracy, higher cost).
# Only 'gemini-*' ids are valid. The _API_KEY lines default to ${GEMINI_API_KEY};
# set them only if a feature needs a separate Gemini project/key.
# ═════════════════════════════════════════════════════════════════════════════

# ── AGENTIC CHAT (FarmMind /ai/chat — Writer → Enhancer) ─────────────────────
# Two-stage chat: Writer drafts → Enhancer fact-checks & rewrites (+ a follow-up
# suggester). Set AI_CHAT_ENHANCER_ENABLED=false for a single Writer pass
# (cheaper/faster, fewer tokens).
AI_CHAT_WRITER_MODEL=gemini-2.5-flash
AI_CHAT_ENHANCER_MODEL=gemini-2.5-flash
AI_CHAT_ENHANCER_ENABLED=true
# General image understanding inside chat (NOT crop-disease, which is /ai/scan).
AI_CHAT_VISION_MODEL=gemini-2.5-flash

# ── SOIL HEALTH CARD OCR (vision — /ai/soil-card-ocr) ────────────────────────
AI_SOIL_OCR_MODEL=gemini-2.5-flash

# ── CROP DISEASE DIAGNOSE (vision — /ai/scan first stage) ────────────────────
AI_CROP_DIAGNOSE_MODEL=gemini-2.5-flash

# ── CROP DISEASE TREATMENT (RAG-grounded plan generation) ────────────────────
AI_CROP_TREATMENT_MODEL=gemini-2.5-flash

# ── SMART FARM ALERTS (/ai/alerts — JSON list of 4-6 alerts) ────────────────
AI_ALERT_MODEL=gemini-2.5-flash

# ── PEST PREDICTION (KisanRakshak enhancement — /pest/predict) ──────────────
AI_PEST_MODEL=gemini-2.5-flash

# ═════════════════════════════════════════════════════════════════════════════
# Example: move crop diagnosis to the more accurate Gemini Pro tier
#   AI_CROP_DIAGNOSE_MODEL=gemini-2.5-pro
# ═════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# 7. Pipeline behaviour (rarely changed)
# ─────────────────────────────────────────────────────────────────────────────
PIPELINE_DEFAULT_TIER=fast
ALLOW_BEST_TIER=true

# Cascade-into-ensemble is disabled by default. The ensemble system (parallel
# fan-out across multiple models for hard cases) is preserved in the codebase
# but turned off in favour of the simpler single-model flow.
ENABLE_ENSEMBLE=false
ENSEMBLE_ESCALATE_BELOW=0.80
ENSEMBLE_AMBIGUOUS_DELTA=0.10
DIAGNOSIS_ESCALATE_BELOW=0.5
# Skip the (2-4x cost) ensemble when the user's remaining daily budget is below
# this USD reserve (AISVC-5) — prevents a single near-cap request from overrunning.
ENSEMBLE_MIN_BUDGET_USD=0.05

# ─────────────────────────────────────────────────────────────────────────────
# Daily spend cap (secondary global guardrail; per-user credits are the
# authoritative budget, enforced in the Express backend).
# ─────────────────────────────────────────────────────────────────────────────
SPEND_CAP_ENABLED=true
DAILY_SPEND_CAP_USD=1.00
ANONYMOUS_DAILY_CAP_USD=0.10
# When a Redis URL is configured, the cap is shared across replicas. If Redis is
# unreachable, fail CLOSED (deny) rather than degrade to per-replica accounting.
# Set false to prefer availability over a strict cap.
SPEND_CAP_REQUIRE_REDIS=true


# ─────────────────────────────────────────────────────────────────────────────
# 8. Persistence
# ─────────────────────────────────────────────────────────────────────────────
DIAGNOSIS_PERSISTENCE_ENABLED=true
