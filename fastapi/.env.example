# ─────────────────────────────────────────────────────────────────────────────
# CropSetu FastAPI AI Service — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
API_HOST=0.0.0.0
API_PORT=8001

# ── Database (same Postgres as Node backend) ─────────────────────────────────
# Shared with the Node service — Railway exposes this via plugin link.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── AI providers ─────────────────────────────────────────────────────────────
# Gemini — vision (crop disease scan).
GEMINI_API_KEY=

# Groq — primary text AI.
GROQ_API_KEY=

# Anthropic — fallback text AI.
ANTHROPIC_API_KEY=

# ── External data ────────────────────────────────────────────────────────────
# data.gov.in — mandi prices (AgriPredict sync).
DATA_GOV_API_KEY=

# OpenWeather — weather data for pest risk + irrigation calc.
OPENWEATHER_API_KEY=

# ── CORS (for direct browser access to /docs, if any) ────────────────────────
AI_ALLOWED_ORIGINS=http://localhost:3001,https://api.cropsetu.com
