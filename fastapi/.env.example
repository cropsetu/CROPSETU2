# ═════════════════════════════════════════════════════════════════════════════
# CropSetu FastAPI AI Service — Environment Variables
#
# How model selection works (the important bit)
#   Each AI feature has exactly TWO lines you control:
#     AI_<FEATURE>_MODEL=<exact-model-id>
#     AI_<FEATURE>_API_KEY=<key for that provider>
#
#   The provider (Anthropic, Groq, OpenAI, Gemini, DeepSeek, xAI, ...) is
#   auto-detected from the model name prefix. You never set "provider"
#   explicitly. To swap a feature to a different provider, change BOTH lines
#   together — model name + matching key. Save → uvicorn hot-reloads → done.
#
#   There is NO fallback chain. If your chosen model is down, the call fails.
#   You then edit .env to point at a different model. This trade-off gives
#   you full visibility — you always know which model served each request.
# ═════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# 1. Server
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=8001


# ─────────────────────────────────────────────────────────────────────────────
# 2. Database & cache
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis — idempotency cache (db 0) + Celery broker/results (db 1).
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Rate-limit storage. SlowAPI is per-process by default, so in a multi-instance
# deployment the limit is enforced PER INSTANCE (effectively N× looser). Point it
# at Redis to share the window across the fleet. Defaults to REDIS_URL when set,
# else in-memory. Falls back to in-memory automatically if Redis is unreachable.
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379/2
# REDIS_URL=redis://localhost:6379/0


# ─────────────────────────────────────────────────────────────────────────────
# 3. API KEYS — set the ones you have. Each AI_<F>_API_KEY below references
#    one of these (or a literal value).
# ─────────────────────────────────────────────────────────────────────────────
# Anthropic (Claude)  → https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Groq (free Llama + Whisper) → https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini  → https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (GPT-4o, o1, o3, whisper-1) → https://platform.openai.com/api-keys
OPENAI_API_KEY=

# DeepSeek → https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# xAI Grok → https://console.x.ai
XAI_API_KEY=

# Sarvam (Indic STT/TTS/translate, not an LLM) → https://dashboard.sarvam.ai
SARVAM_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# 4. Other data sources (optional)
# ─────────────────────────────────────────────────────────────────────────────
DATA_GOV_API_KEY=
OPENWEATHER_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# 5. Security
# ─────────────────────────────────────────────────────────────────────────────
# HMAC shared with Express. Generate a fresh 32-byte hex per environment.
AI_SHARED_SECRET=
AI_ALLOWED_ORIGINS=http://localhost:3001


# ═════════════════════════════════════════════════════════════════════════════
# 6. ▼ PER-FEATURE MODEL SELECTION — pick ONE model + ONE key per feature ▼
# ═════════════════════════════════════════════════════════════════════════════
#
# How auto-detection picks the provider from the model name:
#
#   model id starts with...    → uses
#   ─────────────────────────────────────────────────────────────────────
#   claude-                    → Anthropic (native SDK)
#   gemini-                    → Google Gemini (native REST)
#   gpt-, o1-, o3-             → OpenAI                (api.openai.com)
#   llama-, mixtral-, whisper- → Groq                  (api.groq.com)
#   deepseek-                  → DeepSeek              (api.deepseek.com)
#   grok-                      → xAI                   (api.x.ai)
#   anything else              → REQUIRES AI_<F>_BASE_URL set
#
# For unknown providers (OpenRouter, private hosting, Ollama, LM Studio,
# vLLM, Together, Mistral, Cohere, Cerebras, Fireworks, Perplexity, etc.)
# just set AI_<F>_BASE_URL to their /v1 endpoint — they all speak the same
# OpenAI-compatible protocol.
# ═════════════════════════════════════════════════════════════════════════════


# ── TEXT CHAT (FarmMind Q&A — /ai/chat) ──────────────────────────────────────
# Legacy single-pass chat model (kept for back-compat; the agentic pipeline below
# is what /ai/chat now uses).
AI_TEXT_CHAT_MODEL=llama-3.3-70b-versatile
AI_TEXT_CHAT_API_KEY=${GROQ_API_KEY}


# ── AGENTIC CHAT (FarmMind /ai/chat — Writer → Enhancer) ─────────────────────
# Two-stage chat: Writer drafts → Enhancer fact-checks & rewrites (+ a follow-up
# suggester) = 3 LLM calls per message. Defaults to Gemini 2.5 Flash — fast and
# with much higher free-tier limits than Groq (Groq's free RPM 429s under 3
# calls/message). Keep models FAST (sarvam-30b will time out). Set
# AI_CHAT_ENHANCER_ENABLED=false for a single Writer pass (cheaper/faster).
# To spread load you can split providers, e.g. AI_CHAT_WRITER_MODEL=llama-3.3-70b-versatile.
AI_CHAT_WRITER_MODEL=gemini-2.5-flash
AI_CHAT_WRITER_API_KEY=${GEMINI_API_KEY}
AI_CHAT_ENHANCER_MODEL=gemini-2.5-flash
AI_CHAT_ENHANCER_API_KEY=${GEMINI_API_KEY}
AI_CHAT_ENHANCER_ENABLED=true
# General image understanding inside chat (any photo as context — NOT crop-disease
# diagnosis, which stays in /ai/scan). Must be a vision-capable model.
AI_CHAT_VISION_MODEL=gemini-2.5-flash
AI_CHAT_VISION_API_KEY=${GEMINI_API_KEY}

# ── SOIL HEALTH CARD OCR (vision required — /ai/soil-card-ocr) ───────────────
# Reads a photographed Soil Health Card into the 12 standard parameters.
# Must be a vision-capable model.
AI_SOIL_OCR_MODEL=gemini-2.5-flash
AI_SOIL_OCR_API_KEY=${GEMINI_API_KEY}


# ── CROP DISEASE DIAGNOSE (vision required — /ai/scan first stage) ──────────
# Defaults to Claude Haiku because Gemini's free tier has been unreliable.
AI_CROP_DIAGNOSE_MODEL=claude-haiku-4-5-20251001
AI_CROP_DIAGNOSE_API_KEY=${ANTHROPIC_API_KEY}


# ── CROP DISEASE TREATMENT (RAG-grounded plan generation) ────────────────────
AI_CROP_TREATMENT_MODEL=claude-haiku-4-5-20251001
AI_CROP_TREATMENT_API_KEY=${ANTHROPIC_API_KEY}


# ── SMART FARM ALERTS (/ai/alerts — JSON list of 4-6 alerts) ────────────────
AI_ALERT_MODEL=llama-3.3-70b-versatile
AI_ALERT_API_KEY=${GROQ_API_KEY}


# ── PEST PREDICTION (KisanRakshak enhancement — /pest/predict) ──────────────
AI_PEST_MODEL=llama-3.3-70b-versatile
AI_PEST_API_KEY=${GROQ_API_KEY}


# ── VOICE TRANSCRIPTION (Whisper) ────────────────────────────────────────────
# This pair is also read by the Express backend; mirror these two lines in
# backend/.env if you keep them separate.
AI_VOICE_STT_MODEL=whisper-large-v3-turbo
AI_VOICE_STT_API_KEY=${GROQ_API_KEY}


# ═════════════════════════════════════════════════════════════════════════════
# Example swap workflows (copy + adjust)
# ═════════════════════════════════════════════════════════════════════════════
#
# Swap chat to OpenAI GPT-4o:
#   AI_TEXT_CHAT_MODEL=gpt-4o
#   AI_TEXT_CHAT_API_KEY=${OPENAI_API_KEY}
#
# Swap pest enhancement to DeepSeek:
#   AI_PEST_MODEL=deepseek-chat
#   AI_PEST_API_KEY=${DEEPSEEK_API_KEY}
#
# Swap diagnose to Gemini 2.5 Pro (paid tier):
#   AI_CROP_DIAGNOSE_MODEL=gemini-2.5-pro
#   AI_CROP_DIAGNOSE_API_KEY=${GEMINI_API_KEY}
#
# Use a model on a custom endpoint (OpenRouter / Ollama / vLLM / private):
#   AI_TEXT_CHAT_MODEL=anthropic/claude-3.5-sonnet
#   AI_TEXT_CHAT_API_KEY=sk-or-...                      # OpenRouter key
#   AI_TEXT_CHAT_BASE_URL=https://openrouter.ai/api/v1  # required for unknown prefixes
# ═════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# 7. Pipeline behaviour (rarely changed)
# ─────────────────────────────────────────────────────────────────────────────
PIPELINE_DEFAULT_TIER=fast
ALLOW_BEST_TIER=true

# Cascade-into-ensemble is disabled by default. The ensemble system (parallel
# fan-out across multiple models for hard cases) is preserved in the codebase
# but turned off in favour of the simpler single-model flow.
ENABLE_ENSEMBLE=false
ENSEMBLE_ESCALATE_BELOW=0.80
ENSEMBLE_AMBIGUOUS_DELTA=0.10
DIAGNOSIS_ESCALATE_BELOW=0.5


# ─────────────────────────────────────────────────────────────────────────────
# 8. Persistence
# ─────────────────────────────────────────────────────────────────────────────
DIAGNOSIS_PERSISTENCE_ENABLED=true
