  saleTotalRevenueInr Decimal?  @db.Decimal(14, 2)
  saleBuyerType       String?
  saleBuyerName       String?
  saleDate            DateTime?
  saleMandiName       String?

  // Financials
  totalInputCostInr Decimal? @db.Decimal(14, 2)
  laborCostInr      Decimal? @db.Decimal(14, 2)
  machineryCostInr  Decimal? @db.Decimal(14, 2)
  otherCostInr      Decimal? @db.Decimal(14, 2)
  grossIncomeInr    Decimal? @db.Decimal(14, 2)
  netProfitInr      Decimal? @db.Decimal(14, 2)
  profitPerAcreInr  Decimal? @db.Decimal(14, 2)

  status    CycleStatus @default(ACTIVE)
