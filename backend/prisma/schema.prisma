generator client {
  provider        = "prisma-client-js"
  // postgresqlExtensions: lets the schema declare pg_trgm so trigram GIN indexes
  // (which accelerate ILIKE '%term%' substring search) are managed by Prisma and
  // not dropped by `prisma db push`.
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

model User {
  id                       String               @id @default(uuid())
  phone                    String               @unique
  // Optional contact email. Nullable + unique — Postgres allows many NULLs, so
  // farmers who never add one don't collide. Stored lowercased/trimmed.
  email                    String?              @unique
  name                     String?
  avatar                   String?
  statusQuote              String?
  role                     Role                 @default(FARMER)
  // Admin RBAC sub-role scopes. An ADMIN with an EMPTY array = SUPER_ADMIN, so
  // existing admins keep full access until scopes are deliberately assigned.
  adminScopes              String[]             @default([])
  language                 String               @default("en")
  isActive                 Boolean              @default(true)
  // Bumped on security-sensitive changes (e.g. phone change). Access tokens
  // embed the version at issue time; a stale version is rejected at auth.
  tokenVersion             Int                  @default(0)
  pincode                  String?
  district                 String?
  city                     String?
  state                    String?              @default("Maharashtra")
  // Encrypted at rest (AES-256-GCM ciphertext string). Decrypt to a Float in
  // app code before any geo math — see utils/encrypt.js + cropReportShare routes.
  lat                      String?
  lng                      String?
  isOnline                 Boolean              @default(false)
  lastSeenAt               DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  businessType             String?
  gstNumber                String?
  gstOptOut                Boolean              @default(false)
  kycStatus                KycStatus            @default(PENDING)
  profileCompletion        Int                  @default(0)
  taluka                   String?
  village                  String?
  aadhaarLast4             String?
  activeFarmId             String?
  // Encrypted at rest (AES-256-GCM ciphertext string). Decrypt to a number on read.
  annualHouseholdIncome    String?
  dateOfBirth              DateTime?
  // ── DPDP Act §9 (children's data) ──────────────────────────────────────────
  // isMinor is derived from dateOfBirth (< 18) and persisted so it can gate
  // restricted flows without recomputing. guardianConsentAt records verifiable
  // parental/guardian consent (the lawful basis to process a child's data).
  isMinor                  Boolean              @default(false)
  guardianConsentAt        DateTime?
  dependents               Int?
  education                Education?
  familySize               Int?
  farmingExperienceYrs     Int?
  gender                   Gender?
  hasKisanCreditCard       Boolean              @default(false)
  hasPmKisanAccount        Boolean              @default(false)
  hasSoilHealthCard        Boolean              @default(false)
  lastActiveAt             DateTime?
  onboardingStep           OnboardingStep       @default(BASIC)
  preferredContactMethod   String?
  preferredMandi           String?
  totalFarms               Int                  @default(0)
  totalLandAcres           Float                @default(0)
  aiConversations          AIConversation[]
  aiCredits                AICredit?
  aiUsage                  AIUsage[]
  animalListings           AnimalListing[]
  bookings                 Booking[]
  cartItems                CartItem[]
  chatsAsBuyer             Chat[]               @relation("BuyerChats")
  chatsAsSeller            Chat[]               @relation("SellerChats")
  commentLikes             CommentLike[]
  comments                 Comment[]
  consentRecords           ConsentRecord[]
  cropCalendars            CropCalendar[]
  cropDiseaseReports       CropDiseaseReport[]
  cropReportSharesAsFarmer CropReportShare[]    @relation("CropReportSharesByFarmer")
  cropReportSharesAsSeller CropReportShare[]    @relation("CropReportSharesToSeller")
  dmsReceived              DirectMessage[]      @relation("DMsReceived")
  dmsSent                  DirectMessage[]      @relation("DMsSent")
  diseaseFeedbacks         DiseaseFeedback[]
  farmCropCycles           FarmCropCycle[]
  farmDetail               FarmDetail?
  farmSoilReports          FarmSoilReport[]
  farmWeatherHistories     FarmWeatherHistory[]
  farmerPredictions        FarmerPrediction[]
  farms                    Farm[]               @relation("FarmerFarms")
  groupMembers             GroupMember[]
  groupMessages            GroupMessage[]       @relation("GroupMessagesSent")
  groupsCreated            Group[]              @relation("GroupsCreated")
  irrigationLogs           IrrigationLog[]
  labourListings           LabourListing[]
  machineryListings        MachineryListing[]
  notifications            Notification[]
  orders                   Order[]
  otpSessions              OtpSession[]
  plannerTasks             PlannerTask[]
  postBookmarks            PostBookmark[]
  postLikes                PostLike[]
  posts                    Post[]
  priceAlerts              PriceAlert[]
  sellerProducts           Product[]            @relation("SellerProducts")
  pushTokens               PushToken[]
  refreshTokens            RefreshToken[]
  reviews                  Review[]
  savedAddresses           SavedAddress[]
  schemeApplications       SchemeApplication[]
  sellerProfile            SellerProfile?
  soilHealthRecords        SoilHealthRecord[]
  activeFarm               Farm?                @relation("ActiveFarm", fields: [activeFarmId], references: [id], onDelete: SetNull)
  voiceSessions            VoiceSession[]
  voiceConversations       VoiceConversation[]
  deviceLinks              DeviceAccountLink[]

  @@index([phone])
  @@index([district])
  @@index([kycStatus])
  @@index([activeFarmId])
  @@index([lastActiveAt(sort: Desc)])
  @@map("users")
}

model SellerProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  bankHolderName    String?
  bankName          String?
  bankAccountNumber String?
  bankIfsc          String?
  aadharNumber      String?
  panNumber         String?
  kycDocumentUrls   String[]
  kycVerifiedAt     DateTime?
  kycRejectedReason String?
  // ── Krushi Seva Kendra licence (dedicated Kendra onboarding website) ─────────
  // A Kendra registers with its agri-input dealer licence; an admin verifies the
  // licence + documents (User.kycStatus → VERIFIED) BEFORE the Kendra is approved
  // and becomes discoverable to nearby farmers (see cropReportShare routes — only
  // VERIFIED Kendras surface). Number/type/state/expiry are business-registration
  // data (not personal PII) so stored plaintext; the licence document scans go to
  // PRIVATE Cloudinary storage (public_ids only) exactly like KYC docs and are
  // served via short-lived signed URLs. licenceVerifiedAt is stamped on approval.
  licenceNumber       String?
  licenceType         String?
  licenceIssuingState String?
  licenceExpiry       DateTime?
  licenceDocUrls      String[]  @default([])
  licenceVerifiedAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("seller_profiles")
}

model FarmDetail {
  id             String   @id @default(uuid())
  userId         String   @unique
  village        String?
  district       String?
  state          String?
  pincode        String?
  landAcres      Float?
  cropTypes      String[]
  soilType       String?
  irrigationType String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("farm_details")
}

model OtpSession {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([phone])
  @@index([expiresAt])
  @@map("otp_sessions")
}

model RefreshToken {
  id               String    @id @default(uuid())
  token            String    @unique
  userId           String
  // Rotation lineage: every token minted by rotating a predecessor shares its
  // familyId. Detecting reuse of a rotated token lets us revoke the whole family.
  familyId         String?
  // Set when this token is rotated (used to mint a successor). A non-null value
  // means the token is spent — presenting it again is reuse.
  rotatedAt        DateTime?
  // When the SESSION (lineage) began — preserved across rotations so the server
  // can enforce an absolute session timeout regardless of refresh activity.
  sessionStartedAt DateTime?
  // Idle timeout: a token is only valid until expiresAt; each rotation slides it
  // forward, so a session that goes idle past the window can no longer refresh.
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PushToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  platform  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  nameHi    String?
  nameMr    String?
  nameTa    String?
  nameKn    String?
  nameMl    String?
  nameTe    String?
  nameBn    String?
  nameGu    String?
  namePa    String?
  icon      String?
  color     String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  products  Product[]

  @@map("categories")
}

model Product {
  id              String      @id @default(uuid())
  categoryId      String
  sellerId        String?
  name            String
  nameHi          String?
  nameMr          String?
  description     String?
  price           Decimal     @db.Decimal(12, 2)
  mrp             Decimal?    @db.Decimal(12, 2)
  unit            String      @default("kg")
  stock           Int         @default(0)
  images          String[]
  tags            String[]
  rating          Float       @default(0)
  ratingCount     Int         @default(0)
  isActive        Boolean     @default(true)
  isFeatured      Boolean     @default(false)
  district        String?
  state           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  brand           String?
  countryOfOrigin String?
  harvestDate     String?
  highlights      String[]
  manufacturer    String?
  minOrderQty     Int         @default(1)
  sellScope       String      @default("district")
  specifications  Json?
  subcategory     String?
  taluka          String?
  viewCount       Int         @default(0)
  village         String?
  cartItems       CartItem[]
  orderItems      OrderItem[]
  category        Category    @relation(fields: [categoryId], references: [id])
  seller          User?       @relation("SellerProducts", fields: [sellerId], references: [id])
  reviews         Review[]

  @@index([categoryId])
  @@index([sellerId])
  @@index([district])
  @@index([taluka])
  @@index([isActive, isFeatured])
  @@index([isActive, rating])
  @@index([createdAt])
  // Seller's product list: where sellerId + ORDER BY createdAt DESC.
  @@index([sellerId, createdAt(sort: Desc)])
  // Trigram GIN indexes accelerate the catalogue search (name/description
  // ILIKE '%term%'), which a btree cannot serve due to the leading wildcard.
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "products_name_trgm")
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin, map: "products_description_trgm")
  @@map("products")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("cart_items")
}

model SavedAddress {
  id        String   @id @default(uuid())
  userId    String
  type      String   @default("HOME")
  name      String
  phone     String
  flat      String
  street    String
  city      String
  state     String
  pincode   String
  landmark  String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
  @@map("saved_addresses")
}

model Order {
  id              String      @id @default(uuid())
  userId          String
  status          OrderStatus @default(PENDING)
  totalAmount     Decimal     @db.Decimal(12, 2)
  deliveryAddress Json
  paymentMethod   String      @default("cod")
  paymentStatus   String      @default("pending")
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
  user            User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@index([createdAt])
  // Order history: where userId + ORDER BY createdAt DESC (paginated).
  @@index([userId, createdAt(sort: Desc)])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String
  productId  String
  quantity   Int
  unitPrice  Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)
  sellerId   String?
  // [FIX #4/#13] Per-item status for multi-seller orders. Each seller controls
  // only their own items' status. The overall Order.status is derived from all items.
  status     String  @default("PENDING")
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([sellerId])
  @@index([sellerId, orderId])
  @@map("order_items")
}

// ── Returns / RMA (admin SUPPORT) ─────────────────────────────────────────────
// One buyer-initiated return/refund request against an order (optionally a single
// item). Scalar orderId/userId FKs only — no relation fields on Order/User — so
// this is purely additive. The admin Returns queue (SUPPORT scope) approves /
// rejects / refunds; a REFUNDED resolution flips the linked Order atomically.
model ReturnRequest {
  id           String       @id @default(uuid())
  orderId      String
  orderItemId  String?
  userId       String
  reason       String
  status       ReturnStatus @default(REQUESTED)
  refundAmount Decimal?     @db.Decimal(12, 2)
  resolvedBy   String? // admin userId who approved/rejected/refunded
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@index([orderId])
  @@index([userId])
  @@index([createdAt])
  @@map("return_requests")
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String?
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  product   Product? @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
  // Buyer review history: WHERE userId = ?. A dedicated single-column index for
  // the by-user lookup (narrower than the [userId, productId] unique).
  @@index([userId])
  @@map("reviews")
}

model AnimalListing {
  id             String        @id @default(uuid())
  sellerId       String
  animal         String
  breed          String
  age            String
  gender         AnimalGender
  weight         String
  price          Decimal       @db.Decimal(12, 2)
  milkYield      String?
  description    String?
  images         String[]
  tags           String[]
  verified       Boolean       @default(false)
  status         ListingStatus @default(ACTIVE)
  sellerLocation String
  viewCount      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lat            Float?
  lng            Float?
  seller         User          @relation(fields: [sellerId], references: [id])
  chats          Chat[]

  @@index([sellerId])
  @@index([animal])
  @@index([status])
  @@index([createdAt])
  // Seller's listings: where sellerId (+ status inequality) + ORDER BY createdAt DESC.
  @@index([sellerId, createdAt(sort: Desc)])
  // Trigram GIN — accelerates search OR (animal/breed/sellerLocation ILIKE).
  // All three OR'd columns are indexed so the planner can BitmapOr them.
  @@index([animal(ops: raw("gin_trgm_ops"))], type: Gin, map: "animal_listings_animal_trgm")
  @@index([breed(ops: raw("gin_trgm_ops"))], type: Gin, map: "animal_listings_breed_trgm")
  @@index([sellerLocation(ops: raw("gin_trgm_ops"))], type: Gin, map: "animal_listings_sellerLocation_trgm")
  @@map("animal_listings")
}

model Chat {
  id        String        @id @default(uuid())
  listingId String
  sellerId  String
  buyerId   String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  buyer     User          @relation("BuyerChats", fields: [buyerId], references: [id])
  listing   AnimalListing @relation(fields: [listingId], references: [id])
  seller    User          @relation("SellerChats", fields: [sellerId], references: [id])

  @@unique([listingId, buyerId])
  @@index([sellerId])
  @@index([buyerId])
  @@map("chats")
}

model ChatMessage {
  id        String    @id @default(uuid())
  chatId    String
  senderId  String
  text      String?
  imageUrl  String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  chat      Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([chatId, createdAt])
  @@map("chat_messages")
}

model MachineryListing {
  id            String        @id @default(uuid())
  ownerId       String
  name          String
  category      String
  description   String?
  pricePerDay   Decimal       @db.Decimal(12, 2)
  pricePerHour  Decimal?      @db.Decimal(12, 2)
  images        String[]
  location      String
  district      String
  state         String
  available     Boolean       @default(true)
  status        ListingStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  ageYears      Float?
  availableFrom DateTime?
  availableTo   DateTime?
  brand         String?
  features      String[]
  fuelType      String?
  horsePower    String?
  lat           Float?
  lng           Float?
  mileageHours  Int?
  ownerName     String?
  ownerPhone    String?
  pricePerAcre  Decimal?      @db.Decimal(12, 2)
  rating        Float         @default(0)
  ratingCount   Int           @default(0)
  videos        String[]
  bookings      Booking[]
  owner         User          @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([category])
  @@index([district])
  @@index([status])
  @@index([status, category])
  @@index([lat, lng])
  // Trigram GIN — search OR (name/brand/description/location ILIKE).
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "machinery_listings_name_trgm")
  @@index([brand(ops: raw("gin_trgm_ops"))], type: Gin, map: "machinery_listings_brand_trgm")
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin, map: "machinery_listings_description_trgm")
  @@index([location(ops: raw("gin_trgm_ops"))], type: Gin, map: "machinery_listings_location_trgm")
  @@map("machinery_listings")
}

model LabourListing {
  id            String        @id @default(uuid())
  providerId    String
  name          String
  skills        String[]
  pricePerDay   Decimal       @db.Decimal(12, 2)
  groupSize     Int           @default(1)
  experience    String?
  languages     String[]
  location      String
  district      String
  state         String
  available     Boolean       @default(true)
  status        ListingStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  availableFrom DateTime?
  availableTo   DateTime?
  description   String?
  groupName     String?
  image         String?
  images        String[]
  lat           Float?
  leader        String?
  lng           Float?
  phone         String?
  pricePerHour  Decimal?      @db.Decimal(12, 2)
  rating        Float         @default(0)
  ratingCount   Int           @default(0)
  videos        String[]
  bookings      Booking[]
  provider      User          @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@index([district])
  @@index([status])
  @@index([lat, lng])
  // Trigram GIN — search OR (name/leader/description/location ILIKE).
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "labour_listings_name_trgm")
  @@index([leader(ops: raw("gin_trgm_ops"))], type: Gin, map: "labour_listings_leader_trgm")
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin, map: "labour_listings_description_trgm")
  @@index([location(ops: raw("gin_trgm_ops"))], type: Gin, map: "labour_listings_location_trgm")
  @@map("labour_listings")
}

model Booking {
  id                 String            @id @default(uuid())
  userId             String
  machineryListingId String?
  labourListingId    String?
  startDate          DateTime
  endDate            DateTime
  days               Int
  totalAmount        Decimal           @db.Decimal(12, 2)
  status             BookingStatus     @default(PENDING)
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  hours              Int?
  workerCount        Int?              @default(1)
  labourListing      LabourListing?    @relation(fields: [labourListingId], references: [id])
  machineryListing   MachineryListing? @relation(fields: [machineryListingId], references: [id])
  user               User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, status])
  @@index([machineryListingId])
  @@index([labourListingId])
  @@index([startDate, endDate])
  @@index([createdAt])
  // My-bookings (no status filter): where userId + ORDER BY createdAt DESC.
  @@index([userId, createdAt(sort: Desc)])
  @@map("bookings")
}

model Post {
  id           String         @id @default(uuid())
  authorId     String
  category     String
  title        String
  description  String
  images       String[]
  tags         String[]
  likeCount    Int            @default(0)
  commentCount Int            @default(0)
  viewCount    Int            @default(0)
  isPinned     Boolean        @default(false)
  scope        PostScope      @default(ALL)
  district     String?
  city         String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime? // soft-delete tombstone — non-null rows are hidden from all reads
  comments     Comment[]
  bookmarks    PostBookmark[]
  likes        PostLike[]
  author       User           @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@index([category])
  @@index([district])
  @@index([scope, district])
  @@index([createdAt])
  @@index([deletedAt])
  // Trigram GIN — community search OR (title/description ILIKE).
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin, map: "posts_title_trgm")
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin, map: "posts_description_trgm")
  @@map("posts")
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@map("post_likes")
}

model PostBookmark {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@map("post_bookmarks")
}

model Comment {
  id        String        @id @default(uuid())
  postId    String
  authorId  String
  parentId  String?
  text      String
  likeCount Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  likes     CommentLike[]
  author    User          @relation(fields: [authorId], references: [id])
  parent    Comment?      @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[]     @relation("Replies")
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([postId, createdAt])
  @@index([authorId])
  @@map("comments")
}

model CommentLike {
  id        String  @id @default(uuid())
  commentId String
  userId    String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
