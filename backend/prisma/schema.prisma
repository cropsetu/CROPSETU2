// Moderation lifecycle for flagged content (FRAUD-5 → REV-5 admin queue).
enum ModerationStatus {
  PENDING // awaiting moderator review
  APPROVED // reviewed → content is legitimate (cleared)
  REJECTED // reviewed → content removed / hidden
}

enum IncidentCategory {
  DATA_BREACH // confirmed unauthorized access/disclosure of personal data
  UNAUTHORIZED_ACCESS // access attempt/violation without confirmed data loss
  ACCOUNT_TAKEOVER // credential/session compromise of a user account
  TOKEN_COMPROMISE // leaked/replayed auth token or secret
  OTP_ABUSE // OTP brute-force / bombing
  PII_EXPOSURE // PII returned/logged/stored insecurely
  VULNERABILITY // discovered weakness (not yet exploited)
  PHISHING // social-engineering against users/staff
  SYSTEM_COMPROMISE // server/infrastructure compromise
  FRAUD // fraud/abuse signals: refund-chargeback abuse, velocity-limit blocks, etc. (FRAUD-1/FRAUD-2)
  OTHER
}

// Purposes for which we capture consent (DPDP Act §5 — specific & informed).
