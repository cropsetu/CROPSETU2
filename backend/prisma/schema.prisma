  laborLogs   Json @default("[]")
  expenseLogs Json @default("[]")
  incomeLogs  Json @default("[]")

  // Harvest
  harvestYieldKg        Float?
  harvestYieldQuintal   Float?
  harvestYieldPerAcreKg Float?
  harvestQualityGrade   String?
  harvestMoisturePct    Float?

  // Sale
