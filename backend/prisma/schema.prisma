  LOCATION // use of precise geolocation
  MARKETING // promotional / marketing communications
  GUARDIAN_CONSENT // DPDP §9 verifiable parental/guardian consent for a minor
  SELLER_ONBOARDING // explicit opt-in to become a SELLER (role escalation + obligations)
}

