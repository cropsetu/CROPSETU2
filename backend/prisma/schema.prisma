model MandiPrice {
  id          String   @id @default(uuid())
  commodity   String
  commodityHi String?
  variety     String?
  market      String
  district    String
  state       String
  minPrice    Decimal  @db.Decimal(12, 2)
  maxPrice    Decimal  @db.Decimal(12, 2)
  modalPrice  Decimal  @db.Decimal(12, 2)
  arrivalQty  Float?
  priceDate   DateTime
  source      String   @default("data.gov.in")
  fetchedAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([commodity, state, district])
  @@index([commodity, priceDate(sort: Desc)])
  // Every read path prefilters by a date window (priceDate >= since) and sorts
  // newest-first, while commodity/state/district use ILIKE `contains` (not
  // btree-usable). So the date column is the only indexable predicate for the
  // dominant commodity+state queries — this index lets Postgres range-scan the
  // window and satisfy ORDER BY priceDate DESC instead of a full table scan
  // that degrades as the table grows. (DS-3)
  @@index([priceDate(sort: Desc)])
  // /nearby filters `market IN (...)` (equality) within a date window and sorts
  // by (market, priceDate). Composite serves both the lookup and the ordering.
  @@index([market, priceDate(sort: Desc)])
  @@index([expiresAt])
  @@map("mandi_prices")
}

