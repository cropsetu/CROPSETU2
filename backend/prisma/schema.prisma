// ── Audit Log — forensic trail for PII changes, order mutations, auth events ──
model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String // PII_UPDATE, ORDER_STATUS_CHANGE, ORDER_CANCEL, PRODUCT_DELETE, AUTH_LOGIN, etc.
  entity    String // User, Order, Product, Auth
  entityId  String
  before    String? // JSON stringified old values (PII redacted)
  after     String? // JSON stringified new values (PII redacted)
  ip        String?
  requestId String?
  metadata  String? // JSON extra context
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  // Login-risk lookback (runs every login on a high-volume table):
  // where userId + action + createdAt >= since, ORDER BY createdAt DESC.
  @@index([userId, action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ── Content moderation queue — fake-review / fake-listing signals (FRAUD-5) ──
// Suspicious reviews/listings (burst, duplication, new-account heuristics) are
// routed here for human moderation (REV-5 admin queue) rather than auto-removed.
// One flag row per content item; re-assessment upserts the reasons/score.
model ContentFlag {
  id           String           @id @default(uuid())
  entityType   String // 'Review' | 'Product'
  entityId     String
  authorId     String? // user/seller who created the content
  reasons      String[] // ['burst','duplicate','new_account']
  score        Int              @default(0)
  status       ModerationStatus @default(PENDING)
  metadata     String? // JSON extra context
  reviewedById String?
  reviewedAt   DateTime?
  resolution   String? // moderator note on resolve
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([entityType, entityId]) // one flag per item; re-assessment upserts
  @@index([status, createdAt]) // moderation queue: pending, newest first
  @@map("content_flags")
}

// ── Device ↔ account links — multi-account detection (FRAUD-3) ────────────────
// One row per (device, account) pair, observed at login/order. A single device
// fingerprint backing many DISTINCT accounts is the multi-account signal that
// surfaces to review. `fingerprint` is a hashed STRONG device id (the client's
// X-Device-Id) — NOT the coarse User-Agent fingerprint used for velocity
// bucketing, since thousands of users share a UA and would link spuriously.
// Rows age out by lastSeenAt so dormant links don't keep an actor "linked".
model DeviceAccountLink {
  id          String   @id @default(uuid())
  fingerprint String
  userId      String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  seenCount   Int      @default(1)
  lastIp      String?
  lastContext String? // 'login' | 'order' — where the device was last observed
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([fingerprint, userId])
  @@index([fingerprint, lastSeenAt]) // count distinct accounts per device in a window
  @@index([userId])
  @@map("device_account_links")
}

// ── Consent records — DPDP Act §5 lawful-basis proof ─────────────────────────
// Append-only: every grant or withdrawal is a new immutable row. The EFFECTIVE
// consent for a (user, purpose) is the most recent row by createdAt. Each row
// captures the policy version shown, the timestamp, and proof of the request
// (IP + user-agent + how it was captured) so consent can be demonstrated later.
model ConsentRecord {
  id            String         @id @default(uuid())
  userId        String
  purpose       ConsentPurpose
  granted       Boolean // true = granted, false = withdrawn
  policyVersion String // version of the terms/privacy notice presented (e.g. "2026-06-01")
  method        String? // how it was captured: "signup", "settings_toggle", "api"
  ip            String? // proof: request IP at the time of action
  userAgent     String? // proof: client user-agent at the time of action
  metadata      String? // JSON: any extra context (e.g. screen, locale)
  createdAt     DateTime       @default(now())
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, purpose])
  @@index([purpose])
  @@index([createdAt])
  @@map("consent_records")
}

// ── Security incident log — breach-notification tracking (DPDP §8(6)) ─────────
// One row per detected/reported incident. The notification fields record the
// statutory duty to inform the Data Protection Board of India and the affected
// data principals. Each incident has an append-only IncidentUpdate timeline.
model SecurityIncident {
  id                   String           @id @default(uuid())
  title                String
  description          String?
  category             IncidentCategory
  severity             IncidentSeverity
  status               IncidentStatus   @default(OPEN)
  source               String? // 'system' (auto-detected) | 'manual' | subsystem name
  detectedAt           DateTime         @default(now())
  reportedById         String? // user/admin who reported (null = system-detected)
  affectedUserCount    Int?
  affectedUserIds      String[] // ids of affected data principals (may be empty)
  dataCategories       String[] // PII categories involved, e.g. ['phone','aadhaar','bank']
  // ── Breach-notification duty tracking ──────────────────────────────────────
  notificationRequired Boolean          @default(false)
  notifyDueAt          DateTime? // SLA deadline to notify once required
  boardNotifiedAt      DateTime? // when the Data Protection Board was informed
  usersNotifiedAt      DateTime? // when affected users were informed
  rootCause            String?
  remediation          String?
  metadata             String? // JSON: extra structured context
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  updates              IncidentUpdate[]

  @@index([status])
  @@index([severity])
  @@index([category])
  @@index([detectedAt])
  @@index([notificationRequired, boardNotifiedAt])
  @@map("security_incidents")
}

// Append-only timeline for an incident: notes + status transitions, who & when.
model IncidentUpdate {
  id         String           @id @default(uuid())
  incidentId String
  incident   SecurityIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  authorId   String? // admin who added the note (null = system)
  note       String
  statusFrom IncidentStatus?
  statusTo   IncidentStatus?
  createdAt  DateTime         @default(now())

  @@index([incidentId])
  @@index([createdAt])
  @@map("incident_updates")
}

// ── Seller settlement ledger & payouts (admin WI-4, scope FINANCE) ────────────
// Append-only money ledger per seller plus the payout records computed from it.
// `sellerId` is a User id (a seller's account) kept as a scalar — no FK relation
// is added back onto User so this block stays purely ADDITIVE (zero edits to the
// existing User model / no migrate reset; applied with `prisma db push`).

// One immutable accounting entry against a seller's balance. SALE adds, the rest
// (COMMISSION, REFUND, PAYOUT) subtract; ADJUSTMENT is a signed manual correction.
// `balanceAfter` snapshots the running net balance at write time for auditability.
model SellerLedgerEntry {
  id           String          @id @default(uuid())
  sellerId     String // User id of the seller this entry belongs to
  type         LedgerEntryType
  amount       Decimal         @db.Decimal(12, 2) // signed: positive credits the seller, negative debits
  orderId      String? // source order when the entry derives from a sale/refund
  balanceAfter Decimal         @db.Decimal(12, 2) // running net balance immediately after this entry
  note         String?
  createdBy    String? // admin User id for manual entries (null = system-generated)
  createdAt    DateTime        @default(now())

  @@index([sellerId, createdAt(sort: Desc)])
  @@index([orderId])
  @@index([type])
  @@map("seller_ledger_entries")
}

enum LedgerEntryType {
  SALE
  COMMISSION
  REFUND
  PAYOUT
  ADJUSTMENT
}

// A payout to a seller for a settlement period. Created PENDING with a matching
// PAYOUT ledger entry; an admin then transitions it to PAID/FAILED with a method
// + reference. `sellerId` is a User id (scalar, no relation — additive).
model Payout {
  id          String       @id @default(uuid())
  sellerId    String // User id of the seller being paid
  amount      Decimal      @db.Decimal(12, 2)
  status      PayoutStatus @default(PENDING)
  method      String? // e.g. 'bank_transfer', 'upi'
  reference   String? // bank/UTR reference or failure note
  periodFrom  DateTime // settlement window start (inclusive)
  periodTo    DateTime // settlement window end (inclusive)
  processedBy String? // admin User id who created / last transitioned the payout
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([sellerId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("payouts")
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

// ── Dispute resolution (WI-6) — Animal Trade / Rent booking / Order disputes ──
// A dispute is a support/moderation case opened against a transaction. `refId`
// points at the underlying record by `type` (a Chat/AnimalListing for ANIMAL_TRADE,
// a Booking for RENT_BOOKING, an Order for ORDER) — kept as a loose scalar (NOT a
// hard FK) so a dispute survives the deletion of the thing it references and so
// one model spans three heterogeneous targets. Linked context is resolved on read
// (with PII masked). Created/triaged by admins/support; see disputes.routes.js.
model Dispute {
  id          String        @id @default(uuid())
  type        DisputeType
  refId       String // id of the Chat/AnimalListing (ANIMAL_TRADE) | Booking (RENT_BOOKING) | Order (ORDER)
  raisedBy    String // user id who raised it
  againstUser String? // user id the dispute is against (optional)
  reason      String
  status      DisputeStatus @default(OPEN)
  resolution  String? // moderator resolution note (set on RESOLVED/CLOSED)
  assignedTo  String? // admin user id the case is assigned to
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("disputes")
}

enum DisputeType {
  ANIMAL_TRADE
  RENT_BOOKING
  ORDER
}

enum DisputeStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

// Reusable, multilingual push-notification template. titleI18n/bodyI18n hold the
// 9 supported languages (en + hi/mr/ta/kn/ml/te/bn/gu/pa) as JSON maps keyed by
// language code; a broadcast may resolve its title/body from a template by `key`.
// Soft-deleted via isActive=false so a template referenced by historical sends
// stays resolvable in the audit/history trail.
model NotificationTemplate {
  id        String   @id @default(uuid())
  key       String   @unique
  titleI18n Json
  bodyI18n  Json
  category  String   @default("general")
  isActive  Boolean  @default(true)
  createdBy String? // admin who created the template (null = system/seed)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@index([createdAt])
  @@map("notification_templates")
}

// One row per admin broadcast send — the delivery/broadcast history with real
// estimated/sent/failed counts. `filters` records the audience target, and
// `templateKey` links back to the NotificationTemplate when the send was composed
// from one. Append-only; surfaced by GET /admin/notifications/history.
model BroadcastLog {
  id          String   @id @default(uuid())
  sentBy      String? // admin who sent the broadcast (null = system)
  filters     Json
  title       String
  body        String
  templateKey String?
  estimated   Int      @default(0)
  sent        Int      @default(0)
  failed      Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([sentBy])
  @@index([templateKey])
  @@index([createdAt])
  @@map("broadcast_logs")
}
