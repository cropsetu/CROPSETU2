# ─────────────────────────────────────────────────────────────────────────────
# CropSetu Backend — Environment Variables (template)
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# On Railway, set these under the service's Variables tab.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
API_PREFIX=/api/v1

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Railway sets this automatically when you attach a PostgreSQL plugin.
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Connection pool (Prisma). One pool per app instance. Default is computed as
# max(cpus*2+1, 20) — enough to serve the 1000-user target without pool
# exhaustion. CONSTRAINT: instances × DB_CONNECTION_LIMIT must stay under your
# Postgres max_connections (default 100). For true 1000-connection scale, put a
# pooler (PgBouncer transaction mode / Prisma Accelerate) in front and point
# DATABASE_URL at it. DB_POOL_TIMEOUT = seconds a query waits for a free
# connection before erroring.
# DB_CONNECTION_LIMIT=20
# DB_POOL_TIMEOUT=20

# ── Redis ────────────────────────────────────────────────────────────────────
# Railway sets this automatically when you attach a Redis plugin.
# Used for Socket.IO adapter + rate limiting + the BullMQ job queue.
REDIS_URL=redis://default:password@host:6379

# ── Job queue (BullMQ) ───────────────────────────────────────────────────────
# Offloads heavy side-effects (e.g. notification delivery) off the request path
# to a worker, so requests return immediately. If Redis is down the queue fails
# OPEN — the job runs inline — so nothing is dropped (just loses the offload).
# QUEUE_ENABLED=true            # set false to always run jobs inline (no queue)
# QUEUE_INPROCESS_WORKER=true   # process jobs in the web process. Set false AND
#                               # run a separate `npm run worker` to scale the
#                               # worker tier independently of the web tier.
# QUEUE_CONCURRENCY=5           # max jobs a single worker runs at once

# ── FastAPI AI service URL ───────────────────────────────────────────────────
# On Railway, use the private service URL: http://<service-name>.railway.internal:8001
# In dev: http://localhost:8001
AI_BACKEND_URL=http://cropsetu-ai.railway.internal:8001

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
# Server-side session timeouts (enforced on refresh): idle slides with activity;
# absolute is a hard cap on total session lifetime from first login.
SESSION_IDLE_TIMEOUT_DAYS=7
SESSION_ABSOLUTE_TIMEOUT_DAYS=30
# Max concurrent sessions per user; a new login evicts the oldest. 0 = unlimited.
MAX_CONCURRENT_SESSIONS=5
# Max simultaneous Socket.IO connections per user, per instance. Bounds WS handles
# so a reconnect-loop / abusive client can't exhaust the instance. Over the cap,
# new sockets are refused (existing ones keep working).
SOCKET_MAX_CONN_PER_USER=10

# ── Field-level PII Encryption (AES-256-GCM) ─────────────────────────────────
# Generate: openssl rand -hex 32   (must be a 64-char hex string = 32 bytes)
# REQUIRED in ALL environments — the server refuses to start without a valid
# key so Aadhaar, PAN and bank numbers are never written to the DB in plaintext.
# This is the legacy key, always available under key id "0".
FIELD_ENCRYPTION_KEY=
#
# ── Key rotation (optional) ──────────────────────────────────────────────────
# Additional decryption keys as comma-separated "id:hexkey" pairs (id "0" is
# reserved for FIELD_ENCRYPTION_KEY above). All listed keys can DECRYPT data.
#   FIELD_ENCRYPTION_KEYS=2:<64-char-hex>,3:<64-char-hex>
# Which key encrypts NEW data (must be "0" or an id from FIELD_ENCRYPTION_KEYS):
#   FIELD_ENCRYPTION_ACTIVE_KEY_ID=2
# To rotate with zero downtime: add the new key, set it active, deploy, then run
#   npm run rotate:keys        (preview with: npm run rotate:keys:dry)
# Once it reports 0 remaining, the old key can be retired in a later deploy.
FIELD_ENCRYPTION_KEYS=
FIELD_ENCRYPTION_ACTIVE_KEY_ID=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins (browser clients). Mobile apps send no Origin header.
ALLOWED_ORIGINS=https://admin.cropsetu.com,https://cropsetu.com
# Seconds browsers may cache a CORS preflight (Access-Control-Max-Age) to skip the
# extra OPTIONS round-trip. Default 600 (10 min); browsers cap it. 0 disables.
CORS_MAX_AGE=600

# ── Rate limits ──────────────────────────────────────────────────────────────
# Trusted reverse-proxy hops in front of the app. Required for the per-IP limiter
# to see the real client IP (req.ip) instead of the proxy's. MUST equal the number
# of proxies that prepend X-Forwarded-For — setting it too high lets clients spoof
# their IP and bypass the limiter. Railway edge proxy = 1 (the prod default).
# Accepts a number, true/false, or an Express trust-proxy string ('loopback').
TRUST_PROXY=1
# Global per-IP limiter (all routes). Enabled by default in dev/prod; auto-off
# under the test suite. Set RATE_LIMIT_ENABLED=false to disable, =true to force.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Fail-closed for the Redis-only AI cost limiters when Redis is unavailable:
# reject with 503 instead of allowing unlimited requests across the fleet.
# Defaults ON in production, OFF in dev/test. OTP/global/user limiters are
# unaffected (they keep a per-instance in-memory fallback). Set =false to prefer
# availability of AI routes over abuse protection during a Redis outage.
RATE_LIMIT_FAIL_CLOSED=true
# Cache warming: preload the hottest mandi-price keys on startup + every 25 min so
# the first post-deploy request hits a warm cache instead of the cold Groq latency.
# On by default; auto-off under tests. No-ops gracefully if GROQ_API_KEY is unset.
CACHE_WARMING_ENABLED=true
# Cache observability alert thresholds (see utils/cacheMetrics.js). A 5-min check
# emits a [ALERT] log when the windowed cache hit rate drops below this fraction
# (0..1) or Redis used-memory exceeds this % of maxmemory. Metrics are on /readyz.
CACHE_HIT_RATE_ALERT_THRESHOLD=0.5
REDIS_MEMORY_ALERT_PCT=85
# OTP send limits — sliding window (default 1h) per phone and per IP.
OTP_RATE_LIMIT_WINDOW_MS=3600000
OTP_RATE_LIMIT_MAX=5
OTP_IP_RATE_LIMIT_MAX=50
# Verify-attempt rate limits (short window) — cap rapid OTP guessing.
OTP_VERIFY_RATE_LIMIT_WINDOW_MS=60000
OTP_VERIFY_RATE_LIMIT_MAX=10
OTP_VERIFY_IP_RATE_LIMIT_MAX=30

# ── OTP (MSG91) ──────────────────────────────────────────────────────────────
# Get keys: https://msg91.com — leave blank for dev (OTP returned in response).
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=CROPSE
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=5
# DEV-ONLY auth bypass: when "true" (and NODE_ENV != production and no MSG91 key),
# verifyOtp accepts the fixed OTP "000000" so you can log in without SMS. Leave
# UNSET/false everywhere real. It is hard-forced off in production and the server
# REFUSES TO BOOT if set to true under NODE_ENV=production.
OTP_DEV_BYPASS_ENABLED=false
# Brute-force lockout: lock a number after N failed verifications, with
# exponential backoff (base × 2^(cycle-1), capped) tracked in Redis by phone.
OTP_LOCK_THRESHOLD=5
OTP_LOCK_BASE_SECONDS=60
OTP_LOCK_MAX_SECONDS=3600
OTP_FAIL_WINDOW_SECONDS=900
OTP_LOCK_CYCLE_WINDOW_SECONDS=86400

# ── Cloudinary (image uploads) ───────────────────────────────────────────────
# Required for product/animal/rent listing photos.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── AI (Gemini / Groq / Claude / OpenAI) ─────────────────────────────────────
# Gemini — crop image scanning (vision). Free: 10 RPM.
# Get: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq — primary text AI (chat, planner, alerts). Free: 30 RPM / 14,400 RPD.
# Get: https://console.groq.com
GROQ_API_KEY=

# Anthropic — fallback text AI. Paid.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── AI Credits & token metering (company policy) ────────────────────────────
# Credits are debited per ACTUAL tokens used: credits = ceil(tokens / TOKENS_PER_CREDIT),
# never below a per-feature floor. Free users get a monthly grant (auto-refill 1st).
# Change these any time to update pricing — no code change needed.
AI_TOKENS_PER_CREDIT=1000        # 100 credits ≈ 1 lakh tokens
AI_FREE_MONTHLY_CREDITS=100      # free credits granted per month
AI_MIN_CREDITS_PER_CALL=1        # minimum debit per billable AI call

# OpenAI — optional.
OPENAI_API_KEY=

# ── Weather ──────────────────────────────────────────────────────────────────
# OpenWeatherMap free tier (1000 calls/day).
OPENWEATHER_API_KEY=

# ── Sarvam AI (Indian STT/TTS/Translation for voice chat) ────────────────────
SARVAM_API_KEY=

# ── data.gov.in (Mandi market prices) ────────────────────────────────────────
# Register: https://data.gov.in → profile → API key
DATA_GOV_API_KEY=

# ── Razorpay (payments) ──────────────────────────────────────────────────────
# Test keys: https://dashboard.razorpay.com/app/keys
# Leave blank for dev mock mode.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
